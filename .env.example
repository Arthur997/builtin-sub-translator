# Chave da API do TorBox (https://torbox.app -> Settings -> API)
TORBOX_API_KEY=

# Chave da API do Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# URL pública/LAN pela qual o DISPOSITIVO DO PLAYER alcança este addon.
# NÃO use localhost se for assistir noutro aparelho. Use a PORTA DO HOST mapeada
# no docker-compose.yml (ex.: 3044), não a porta interna do container.
# Ex.: http://192.168.0.10:3044 ou um túnel (ngrok/cloudflared). Sem barra no final.
BASE_URL=http://127.0.0.1:3044

# Diretório de cache das legendas traduzidas.
CACHE_DIR=cache

# Porta interna do servidor DENTRO do container (não mude sem também ajustar o
# mapeamento de portas no docker-compose.yml).
PORT=7000

# (Opcional) Modelo do Gemini.
GEMINI_MODEL=gemini-2.5-flash
